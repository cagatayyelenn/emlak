Options -MultiViews
RewriteEngine On
RewriteBase /

# İlan detay sayfası yönlendirmesi
# Örn: /ilan/satilik-villa-ilani -> ilan-detay.php?slug=satilik-villa-ilani
RewriteRule ^ilan/([a-zA-Z0-9-]+)/?$ ilan-detay.php?slug=$1 [L,QSA]

# Diğer sayfalar için otomatik .php dosyasına yönlendirme (örn: /iletisim -> iletisim.php)
# Not: Mevcut dosya varsa yönlendirme yapmaz
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9_-]+)/?$ $1.php [L,QSA]
